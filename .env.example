# Your Google Sheet ID — found in the URL between /d/ and /edit
SPREADSHEET_ID=your_sheet_id_here

# Path to your service account JSON key file downloaded from Google Cloud Console
GOOGLE_CREDENTIALS_PATH=credentials.json

# PostgreSQL connection string — format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/sheetsync

# Which sheet tab to read (usually "Sheet1" unless you renamed it)
SHEET_NAME=Sheet1
